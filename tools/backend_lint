#!/usr/bin/env bash

set -e

BACKEND_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../backend" && pwd)"

run_ruff() {
    cd "$BACKEND_DIR"

    if ! uv run ruff check .; then
        echo "Ruff lint found issues."
        return 1
    fi

    if ! uv run ruff format --check .; then
        echo "Ruff formatting found issues. Run 'uv run ruff format .' to fix them."
        return 1
    fi

    echo "Ruff passed!"
}

run_mypy() {
    cd "$BACKEND_DIR"

    if ! uv run mypy .; then
        echo "Mypy found issues."
        return 1
    fi

    echo "Mypy passed!"
}

run_all() {
    run_ruff
    run_mypy
    echo "All checks passed!"
}

main() {
    if [[ "$1" == "--only=ruff" ]]; then
        run_ruff
    elif [[ "$1" == "--only=mypy" ]]; then
        run_mypy
    else
        run_all
    fi
}

main "$@"
